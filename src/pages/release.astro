---
import {
  ArrowUpRight,
  Boxes,
  Check,
  Clock3,
  Code2,
  FileCheck2,
  GitCommit,
  Tag
} from "lucide-react";
import BaseLayout from "../layouts/BaseLayout.astro";
import { releaseFacts } from "../data/release";

const isReleased = releaseFacts.channel === "released";
const generatedAt =
  `${releaseFacts.generatedAt.slice(0, 16).replace("T", " ")} UTC`;
const baselineHighlights =
  releaseFacts.core.changelog.currentVersion.sections.flatMap(
    (section) => section.items
  ).slice(0, 6);
const manifestUrl =
  "https://github.com/PersonalClaw/personalclaw.dev/blob/main/sources/personalclaw.sources.json";
const changelogUrl = `${releaseFacts.core.source.repositoryUrl}/blob/${releaseFacts.core.source.commit}/CHANGELOG.md`;
---

<BaseLayout
  title="Release provenance · PersonalClaw"
  description="Trace the PersonalClaw version, changelog, app catalog, capabilities, and website claims to exact source commits."
>
  <section
    class="release-hero"
    data-release-provenance
    data-source-channel={releaseFacts.channel}
    data-content-schema={releaseFacts.schemaVersion}
    data-core-commit={releaseFacts.core.source.commit}
    data-apps-commit={releaseFacts.apps.source.commit}
    data-generated-at={releaseFacts.generatedAt}
  >
    <div class="shell release-hero-grid">
      <div class="release-heading">
        <p class="kicker">Release provenance</p>
        <h1>Know exactly what this site describes.</h1>
        <p class="release-lede">
          Product facts are built from pinned PersonalClaw and PersonalClawApps
          revisions. The source state is visible here instead of being hidden
          behind marketing copy.
        </p>
        <div class:list={["source-status", { "is-release": isReleased }]}>
          <Check size={18} aria-hidden="true" />
          <span>{releaseFacts.status.label}</span>
        </div>
      </div>

      <div class="snapshot-summary" aria-label="Pinned source summary">
        <dl>
          <div>
            <dt>Source channel</dt>
            <dd>{isReleased ? "Tagged release" : "Pre-release"}</dd>
          </div>
          <div>
            <dt>Core package</dt>
            <dd>{releaseFacts.core.versionLabel}</dd>
          </div>
          <div>
            <dt>App manifests</dt>
            <dd>{releaseFacts.apps.total}</dd>
          </div>
          <div>
            <dt>Content schema</dt>
            <dd>v{releaseFacts.schemaVersion}</dd>
          </div>
          <div>
            <dt>Build generated</dt>
            <dd data-build-time>{generatedAt}</dd>
          </div>
        </dl>
        <a
          class="text-link"
          href={manifestUrl}
          target="_blank"
          rel="noreferrer"
        >
          View the source manifest <ArrowUpRight size={17} aria-hidden="true" />
        </a>
      </div>
    </div>
  </section>

  <section class="section source-section section-rule">
    <div class="shell">
      <div class="section-head">
        <div>
          <p class="kicker">Exact inputs</p>
          <h2>Two repositories. Two immutable commits.</h2>
        </div>
        <p>{releaseFacts.status.summary}</p>
      </div>

      <div class="source-ledger">
        {
          [
            { label: "Core", source: releaseFacts.core.source },
            { label: "First-party apps", source: releaseFacts.apps.source }
          ].map(({ label, source }) => (
            <article>
              <div class="source-name">
                <span>{label}</span>
                <h3>{source.repository}</h3>
              </div>
              <dl>
                <div>
                  <dt><GitCommit size={17} aria-hidden="true" /> Commit</dt>
                  <dd>
                    <a href={source.commitUrl} target="_blank" rel="noreferrer">
                      <code>{source.shortCommit}</code>
                      <ArrowUpRight size={15} aria-hidden="true" />
                    </a>
                  </dd>
                </div>
                <div>
                  <dt><Tag size={17} aria-hidden="true" /> Tag</dt>
                  <dd>
                    {source.tagUrl ? (
                      <a href={source.tagUrl} target="_blank" rel="noreferrer">
                        {source.tag}
                        <ArrowUpRight size={15} aria-hidden="true" />
                      </a>
                    ) : (
                      <span class="unverified">Not asserted</span>
                    )}
                  </dd>
                </div>
              </dl>
            </article>
          ))
        }
      </div>

      {
        !isReleased && (
          <div class="release-caveat">
            <FileCheck2 size={22} aria-hidden="true" />
            <div>
              <strong>This is a development snapshot, not a release claim.</strong>
              <p>
                The package reports {releaseFacts.core.versionLabel}, but neither
                pinned repository has a verified tag in this manifest. A tagged
                website build must prove that every tag resolves to its declared
                commit before publication.
              </p>
            </div>
          </div>
        )
      }
    </div>
  </section>

  <section class="section app-evidence section-rule">
    <div class="shell">
      <div class="section-head">
        <div>
          <p class="kicker">Manifest evidence</p>
          <h2>The ecosystem count is computed, not typed.</h2>
        </div>
        <p>
          Every number below is derived from the app manifests at the pinned
          PersonalClawApps commit. The website build fails if its public
          directory drifts from those names or categories.
        </p>
      </div>

      <div class="category-ledger" aria-label="Apps by category">
        {
          releaseFacts.apps.categories.map((category) => (
            <div>
              <strong>{category.apps}</strong>
              <span>{category.name}</span>
            </div>
          ))
        }
      </div>

      <div class="capability-heading">
        <div>
          <Boxes size={22} aria-hidden="true" />
          <h3>{releaseFacts.apps.capabilityCount} declared capabilities</h3>
        </div>
        <p>Counted once per app manifest.</p>
      </div>
      <ul class="capability-ledger">
        {
          releaseFacts.apps.capabilities.map((capability) => (
            <li>
              <span>{capability.name}</span>
              <strong>{capability.apps}</strong>
              <small>{capability.apps === 1 ? "app" : "apps"}</small>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="section change-section section-rule">
    <div class="shell change-grid">
      <div class="change-intro">
        <p class="kicker">Changelog truth</p>
        <h2>Package baseline and work after it.</h2>
        <p>
          The release page reads the package version from <code>pyproject.toml</code>
          and locates the matching entry in the same pinned changelog.
        </p>
        <a
          class="text-link"
          href={changelogUrl}
          target="_blank"
          rel="noreferrer"
        >
          Read the pinned changelog <ArrowUpRight size={17} aria-hidden="true" />
        </a>
      </div>

      <div class="change-entries">
        <article>
          <div class="entry-heading">
            <span>After the baseline</span>
            <h3>{releaseFacts.core.changelog.unreleased.heading}</h3>
          </div>
          {
            releaseFacts.core.changelog.unreleased.sections.map((section) => (
              <div class="change-group">
                <h4>{section.title}</h4>
                <ul>
                  {section.items.map((item) => <li>{item}</li>)}
                </ul>
              </div>
            ))
          }
        </article>

        <article>
          <div class="entry-heading">
            <span>Package baseline</span>
            <h3>
              v{releaseFacts.core.changelog.currentVersion.heading}
              {releaseFacts.core.changelog.currentVersion.date && (
                <small>{releaseFacts.core.changelog.currentVersion.date}</small>
              )}
            </h3>
          </div>
          <p>{releaseFacts.core.changelog.currentVersion.summary}</p>
          <ul class="baseline-list">
            {baselineHighlights.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      </div>
    </div>
  </section>

  <section class="section provenance-method section-rule">
    <div class="shell">
      <div class="method-heading">
        <p class="kicker">Publication contract</p>
        <h2>A claim has to survive the build.</h2>
      </div>
      <ol class="method-steps">
        <li>
          <span>01</span>
          <GitCommit size={24} aria-hidden="true" />
          <h3>Pin</h3>
          <p>Declare full 40-character commits and the publication channel.</p>
        </li>
        <li>
          <span>02</span>
          <Code2 size={24} aria-hidden="true" />
          <h3>Parse</h3>
          <p>Read package metadata, changelog entries, and app manifests structurally.</p>
        </li>
        <li>
          <span>03</span>
          <Clock3 size={24} aria-hidden="true" />
          <h3>Record</h3>
          <p>Publish source links, schema version, channel, and build time together.</p>
        </li>
      </ol>
    </div>
  </section>
</BaseLayout>

<style>
  .release-hero {
    padding: clamp(5rem, 10vw, 9rem) 0 clamp(4rem, 8vw, 7rem);
    overflow: hidden;
  }

  .release-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(360px, 0.8fr);
    gap: clamp(3rem, 10vw, 10rem);
    align-items: end;
  }

  h1 {
    max-width: 12ch;
    margin-bottom: 1.6rem;
    font-size: clamp(3.5rem, 8vw, 7.25rem);
    font-weight: 330;
    line-height: 0.94;
  }

  .release-lede {
    max-width: 43rem;
    color: var(--ink-soft);
    font-size: 1.12rem;
  }

  .source-status {
    display: inline-flex;
    min-height: 44px;
    margin-top: 1rem;
    gap: 0.65rem;
    align-items: center;
    color: var(--amber);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
  }

  .source-status.is-release {
    color: var(--success);
  }

  .snapshot-summary {
    padding-left: 1.5rem;
    border-left: 1px solid var(--line-strong);
  }

  .snapshot-summary dl {
    margin: 0 0 1.5rem;
  }

  .snapshot-summary dl div {
    display: grid;
    min-height: 52px;
    grid-template-columns: 1fr 1.25fr;
    gap: 1rem;
    align-items: center;
    border-bottom: 1px solid var(--line);
  }

  .snapshot-summary dt {
    color: var(--ink-muted);
    font-size: 0.82rem;
  }

  .snapshot-summary dd {
    margin: 0;
    color: var(--ink);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    overflow-wrap: anywhere;
  }

  .text-link {
    display: inline-flex;
    min-height: 44px;
    gap: 0.45rem;
    align-items: center;
    color: var(--coral-bright);
    font-weight: 650;
  }

  .text-link:hover {
    color: var(--ink);
  }

  .source-section {
    background: var(--night-soft);
  }

  .source-ledger {
    border-top: 1px solid var(--line-strong);
  }

  .source-ledger article {
    display: grid;
    min-height: 180px;
    padding-block: 1.5rem;
    grid-template-columns: minmax(220px, 0.75fr) minmax(0, 1.25fr);
    gap: 2rem;
    align-items: center;
    border-bottom: 1px solid var(--line-strong);
  }

  .source-name > span,
  .entry-heading > span {
    color: var(--coral-bright);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
  }

  .source-name h3 {
    margin: 0.45rem 0 0;
    font-size: clamp(1.4rem, 3vw, 2.2rem);
    font-weight: 480;
    overflow-wrap: anywhere;
  }

  .source-ledger dl {
    display: grid;
    margin: 0;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--line);
  }

  .source-ledger dl div {
    min-height: 94px;
    padding: 1rem;
    background: var(--surface);
  }

  .source-ledger dt {
    display: flex;
    margin-bottom: 0.75rem;
    gap: 0.45rem;
    align-items: center;
    color: var(--ink-muted);
    font-size: 0.78rem;
  }

  .source-ledger dd {
    margin: 0;
  }

  .source-ledger dd a {
    display: inline-flex;
    min-height: 44px;
    gap: 0.5rem;
    align-items: center;
    color: var(--ink);
  }

  .source-ledger dd a:hover {
    color: var(--coral-bright);
  }

  .source-ledger code,
  .unverified {
    color: var(--amber);
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }

  .release-caveat {
    display: grid;
    max-width: 820px;
    margin: 2rem 0 0 auto;
    padding: 1.25rem 0;
    grid-template-columns: 42px 1fr;
    gap: 0.75rem;
    border-block: 1px solid rgba(255, 180, 84, 0.35);
  }

  .release-caveat > svg {
    color: var(--amber);
  }

  .release-caveat p {
    margin: 0.35rem 0 0;
    color: var(--ink-muted);
  }

  .category-ledger {
    display: grid;
    grid-template-columns: repeat(9, 1fr);
    border-block: 1px solid var(--line-strong);
  }

  .category-ledger div {
    display: grid;
    min-height: 128px;
    padding: 1rem;
    align-content: end;
    border-right: 1px solid var(--line);
  }

  .category-ledger div:last-child {
    border-right: 0;
  }

  .category-ledger strong {
    color: var(--coral);
    font-size: 2rem;
    font-weight: 560;
    line-height: 1;
  }

  .category-ledger span {
    margin-top: 0.55rem;
    color: var(--ink-muted);
    font-size: 0.78rem;
  }

  .capability-heading {
    display: flex;
    margin: 4rem 0 1.25rem;
    gap: 2rem;
    align-items: end;
    justify-content: space-between;
  }

  .capability-heading > div {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }

  .capability-heading svg {
    color: var(--coral);
  }

  .capability-heading h3,
  .capability-heading p {
    margin: 0;
  }

  .capability-heading h3 {
    font-size: 1.3rem;
  }

  .capability-heading p {
    color: var(--ink-muted);
    font-size: 0.82rem;
  }

  .capability-ledger {
    display: grid;
    padding: 0;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid var(--line);
    list-style: none;
  }

  .capability-ledger li {
    display: grid;
    min-height: 58px;
    padding: 0.75rem 1rem 0.75rem 0;
    grid-template-columns: minmax(0, 1fr) auto auto;
    gap: 0.35rem;
    align-items: center;
    border-bottom: 1px solid var(--line);
  }

  .capability-ledger li:not(:nth-child(3n + 1)) {
    padding-left: 1rem;
    border-left: 1px solid var(--line);
  }

  .capability-ledger span {
    color: var(--ink-soft);
  }

  .capability-ledger strong {
    color: var(--coral-bright);
    font-family: var(--font-mono);
    font-size: 0.82rem;
  }

  .capability-ledger small {
    color: var(--ink-muted);
  }

  .change-section {
    background: var(--night-soft);
  }

  .change-grid {
    display: grid;
    grid-template-columns: minmax(280px, 0.65fr) minmax(0, 1.35fr);
    gap: clamp(3rem, 10vw, 10rem);
    align-items: start;
  }

  .change-intro {
    position: sticky;
    top: 110px;
  }

  .change-intro h2,
  .method-heading h2 {
    max-width: 12ch;
    margin-bottom: 1.5rem;
    font-size: clamp(2.5rem, 5.5vw, 5rem);
    font-weight: 390;
    line-height: 1;
  }

  .change-intro > p:not(.kicker) {
    color: var(--ink-soft);
  }

  .change-intro code {
    color: var(--coral-bright);
    font-family: var(--font-mono);
    font-size: 0.85em;
  }

  .change-entries {
    border-top: 1px solid var(--line-strong);
  }

  .change-entries > article {
    padding-block: 2rem;
    border-bottom: 1px solid var(--line-strong);
  }

  .entry-heading {
    display: grid;
    margin-bottom: 1.5rem;
    grid-template-columns: 1fr auto;
    gap: 1rem;
    align-items: baseline;
  }

  .entry-heading h3 {
    margin: 0;
    font-size: 1.7rem;
    font-weight: 520;
  }

  .entry-heading small {
    margin-left: 0.75rem;
    color: var(--ink-muted);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 400;
  }

  .change-group + .change-group {
    margin-top: 1.5rem;
  }

  .change-group h4 {
    margin: 0 0 0.75rem;
    color: var(--ink-muted);
    font-size: 0.76rem;
    text-transform: uppercase;
  }

  .change-group ul,
  .baseline-list {
    display: grid;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .change-group li,
  .baseline-list li {
    padding: 0.85rem 0 0.85rem 1.2rem;
    border-top: 1px solid var(--line);
    color: var(--ink-soft);
  }

  .change-group li::before,
  .baseline-list li::before {
    display: inline-block;
    width: 1.2rem;
    margin-left: -1.2rem;
    color: var(--coral);
    content: "·";
  }

  .change-entries > article > p {
    color: var(--ink-soft);
  }

  .method-heading {
    display: grid;
    grid-template-columns: 0.55fr 1.45fr;
    gap: 2rem;
    align-items: start;
  }

  .method-heading h2 {
    max-width: 14ch;
    margin: 0;
  }

  .method-heading .kicker {
    margin-top: 0.7rem;
  }

  .method-steps {
    display: grid;
    margin: clamp(3rem, 8vw, 7rem) 0 0;
    padding: 0;
    grid-template-columns: repeat(3, 1fr);
    border-block: 1px solid var(--line);
    list-style: none;
  }

  .method-steps li {
    position: relative;
    min-height: 260px;
    padding: 1.5rem;
    border-right: 1px solid var(--line);
  }

  .method-steps li:last-child {
    border-right: 0;
  }

  .method-steps li > span {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    color: var(--ink-muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }

  .method-steps svg {
    margin: 3.75rem 0 2.2rem;
    color: var(--coral);
  }

  .method-steps h3 {
    margin-bottom: 0.4rem;
    font-size: 1.25rem;
  }

  .method-steps p {
    margin: 0;
    color: var(--ink-muted);
  }

  @media (max-width: 1100px) {
    .category-ledger {
      grid-template-columns: repeat(3, 1fr);
    }

    .category-ledger div:nth-child(3n) {
      border-right: 0;
    }

    .category-ledger div:nth-child(-n + 6) {
      border-bottom: 1px solid var(--line);
    }
  }

  @media (max-width: 820px) {
    .release-hero-grid,
    .change-grid,
    .method-heading {
      grid-template-columns: 1fr;
    }

    .snapshot-summary {
      padding: 1.25rem 0 0;
      border-top: 1px solid var(--line-strong);
      border-left: 0;
    }

    .source-ledger article {
      grid-template-columns: 1fr;
    }

    .capability-ledger {
      grid-template-columns: repeat(2, 1fr);
    }

    .capability-ledger li:not(:nth-child(3n + 1)) {
      padding-left: 0;
      border-left: 0;
    }

    .capability-ledger li:nth-child(even) {
      padding-left: 1rem;
      border-left: 1px solid var(--line);
    }

    .change-intro {
      position: static;
    }
  }

  @media (max-width: 560px) {
    h1 {
      font-size: 3.55rem;
    }

    .snapshot-summary dl div,
    .source-ledger dl,
    .entry-heading {
      grid-template-columns: 1fr;
    }

    .snapshot-summary dl div {
      padding-block: 0.65rem;
      gap: 0.15rem;
    }

    .source-ledger dl {
      background: transparent;
    }

    .source-ledger dl div + div {
      border-top: 1px solid var(--line);
    }

    .category-ledger {
      grid-template-columns: 1fr 1fr;
    }

    .category-ledger div,
    .category-ledger div:nth-child(3n) {
      border-right: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
    }

    .category-ledger div:nth-child(even) {
      border-right: 0;
    }

    .category-ledger div:last-child {
      grid-column: 1 / -1;
      border-bottom: 0;
      border-right: 0;
    }

    .capability-heading {
      align-items: start;
      flex-direction: column;
      gap: 0.5rem;
    }

    .capability-ledger,
    .method-steps {
      grid-template-columns: 1fr;
    }

    .capability-ledger li,
    .capability-ledger li:nth-child(even) {
      padding-left: 0;
      border-left: 0;
    }

    .method-steps li {
      min-height: 230px;
      border-right: 0;
      border-bottom: 1px solid var(--line);
    }

    .method-steps li:last-child {
      border-bottom: 0;
    }
  }
</style>
