---
import { Image } from "astro:assets";
import {
  ArrowRight,
  Bot,
  Box,
  Check,
  CirclePause,
  Database,
  Eye,
  KeyRound,
  Network,
  PlugZap,
  ScanSearch,
  ShieldCheck,
  Terminal,
  Workflow
} from "lucide-react";
import appsCapture from "../assets/apps.png";
import loopsCapture from "../assets/loops.png";
import SystemWindow from "../components/SystemWindow.astro";
import { CopyCommand } from "../components/CopyCommand";
import BaseLayout from "../layouts/BaseLayout.astro";
import { releaseFacts } from "../data/release";
import { GITHUB_URL, INSTALL_COMMAND } from "../data/site";

const featuredApps = [
  "OpenAI",
  "Anthropic",
  "Amazon Bedrock",
  "Google Gemini",
  "Ollama",
  "Claude Code",
  "OpenAI Codex",
  "Tavily",
  "Slack Channel",
  "MCP Tool Servers",
  "Minutes",
  "Growth Tracker"
];
---

<BaseLayout>
  <section class="home-hero">
    <div class="hero-window">
      <SystemWindow />
    </div>
    <div class="shell hero-content">
      <div class="hero-copy">
        <img
          class="hero-mark"
          src="/brand/personalclaw-mark.svg"
          alt=""
          width="64"
          height="64"
        />
        <h1>PersonalClaw</h1>
        <p class="hero-line">One agentic OS.<br />Your machine. Your rules.</p>
        <p class="hero-support">
          Chat, autonomous goals, memory, knowledge, and automation behind one
          gateway you own.
        </p>
        <div class="hero-actions">
          <a
            class="button button-primary"
            href={GITHUB_URL}
            target="_blank"
            rel="noreferrer"
          >
            Get PersonalClaw
          </a>
          <a class="button button-secondary" href="#system">
            Explore the system
            <ArrowRight size={18} aria-hidden="true" />
          </a>
        </div>
        <div class="hero-facts" aria-label="Project facts">
          <span><Check size={15} aria-hidden="true" /> MIT licensed</span>
          <span><Check size={15} aria-hidden="true" /> Zero telemetry</span>
          <span><Check size={15} aria-hidden="true" /> Self-hosted</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-rule ownership" id="system">
    <div class="shell">
      <div class="statement">
        <p class="kicker">Built for one owner</p>
        <h2>Not another account. A system that belongs to you.</h2>
      </div>

      <div class="ownership-grid">
        <article>
          <span class="index">01</span>
          <Database size={24} aria-hidden="true" />
          <h3>Your state stays home.</h3>
          <p>
            Conversations, memory, knowledge, configuration, and app state live
            under one PersonalClaw home on infrastructure you control.
          </p>
        </article>
        <article>
          <span class="index">02</span>
          <Eye size={24} aria-hidden="true" />
          <h3>Autonomy stays visible.</h3>
          <p>
            Goal loops expose their plan, current cycle, tool activity, and
            output. Pause, nudge, or stop the work at any time.
          </p>
        </article>
        <article>
          <span class="index">03</span>
          <PlugZap size={24} aria-hidden="true" />
          <h3>Every vendor is removable.</h3>
          <p>
            Model providers, search, speech, channels, tools, and agent runtimes
            connect through an app boundary instead of the core.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section product-story">
    <div class="shell story-layout">
      <div class="story-copy">
        <p class="kicker">Goal loops</p>
        <h2>Delegate an outcome. Keep the controls.</h2>
        <p>
          PersonalClaw classifies a goal, builds a plan, and works cycle by
          cycle under a deterministic supervisor. It can run without constant
          prompting without disappearing behind a spinner.
        </p>
        <ul class="proof-list">
          <li><CirclePause size={19} aria-hidden="true" /> Pause, nudge, or stop a loop</li>
          <li><Workflow size={19} aria-hidden="true" /> Inspect every cycle and result</li>
          <li><ShieldCheck size={19} aria-hidden="true" /> Keep tool approvals in the host</li>
        </ul>
        <a class="text-link" href="/product">
          Tour the product <ArrowRight size={17} aria-hidden="true" />
        </a>
      </div>
      <div class="story-media">
        <Image
          src={loopsCapture}
          alt="A PersonalClaw autonomous goal loop with its progress, steps, and controls visible"
          widths={[640, 960, 1280]}
          sizes="(max-width: 900px) 100vw, 62vw"
          format="webp"
          quality={86}
        />
      </div>
    </div>
  </section>

  <section class="section section-rule architecture">
    <div class="shell">
      <div class="section-head">
        <div>
          <p class="kicker">One local gateway</p>
          <h2>A coherent system, not a pile of prompts.</h2>
        </div>
        <p>
          The gateway coordinates interfaces, agentic work, durable context, and
          permission-gated apps. Core operation remains available without a
          network connection.
        </p>
      </div>

      <div class="system-path" aria-label="PersonalClaw system architecture">
        <article>
          <span>You</span>
          <Terminal size={26} aria-hidden="true" />
          <h3>Dashboard · CLI · channels</h3>
        </article>
        <span class="path-arrow" aria-hidden="true">→</span>
        <article>
          <span>Gateway</span>
          <Network size={26} aria-hidden="true" />
          <h3>One process, one API</h3>
        </article>
        <span class="path-arrow" aria-hidden="true">→</span>
        <article>
          <span>Agentic core</span>
          <Bot size={26} aria-hidden="true" />
          <h3>Chat · loops · automation</h3>
        </article>
        <span class="path-arrow" aria-hidden="true">→</span>
        <article>
          <span>Context</span>
          <Database size={26} aria-hidden="true" />
          <h3>Memory · knowledge · skills</h3>
        </article>
        <span class="path-arrow" aria-hidden="true">→</span>
        <article>
          <span>Apps</span>
          <Box size={26} aria-hidden="true" />
          <h3>Your vendors and tools</h3>
        </article>
      </div>
    </div>
  </section>

  <section class="section ecosystem">
    <div class="shell">
      <div class="ecosystem-intro">
        <div>
          <p class="kicker">First-party ecosystem</p>
          <h2>{releaseFacts.apps.total} apps. No permanent provider.</h2>
        </div>
        <a class="button button-secondary" href="/apps">
          Browse all apps <ArrowRight size={18} aria-hidden="true" />
        </a>
      </div>

      <div class="app-tape" aria-label="Featured first-party apps">
        {featuredApps.map((app) => (
          <span>{app}</span>
        ))}
      </div>

      <div class="ecosystem-stage">
        <div class="ecosystem-note">
          <p>
            Install models, search, tools, speech, channels, ACP agents, and
            complete product interfaces from one permission-aware store.
          </p>
          <dl>
            <div>
              <dt>{releaseFacts.apps.total}</dt>
              <dd>First-party apps</dd>
            </div>
            <div>
              <dt>{releaseFacts.apps.categoryCount}</dt>
              <dd>App categories</dd>
            </div>
            <div>
              <dt>1</dt>
              <dd>App contract</dd>
            </div>
          </dl>
        </div>
        <Image
          src={appsCapture}
          alt="PersonalClaw app store showing installed and available apps"
          widths={[640, 960, 1280]}
          sizes="(max-width: 900px) 100vw, 68vw"
          format="webp"
          quality={86}
        />
      </div>
    </div>
  </section>

  <section class="section security-band">
    <div class="shell security-layout">
      <div class="security-copy">
        <p class="kicker">Security is architecture</p>
        <h2>Autonomy with a boundary.</h2>
        <p>
          The model can propose. Deterministic controls decide what reaches your
          shell, network, and installed app surface.
        </p>
        <a class="text-link" href="/security">
          Inspect the security model <ArrowRight size={17} aria-hidden="true" />
        </a>
      </div>

      <div class="security-controls">
        <article>
          <ShieldCheck size={22} aria-hidden="true" />
          <div>
            <h3>Host approval gate</h3>
            <p>Tool policy remains outside the model and spawned agent.</p>
          </div>
        </article>
        <article>
          <ScanSearch size={22} aria-hidden="true" />
          <div>
            <h3>Quarantine and scanner gate</h3>
            <p>App installation pauses before enablement when risk is detected.</p>
          </div>
        </article>
        <article>
          <KeyRound size={22} aria-hidden="true" />
          <div>
            <h3>Scoped app tokens</h3>
            <p>Apps receive bounded credentials instead of ambient authority.</p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="section quickstart">
    <div class="narrow">
      <p class="kicker">Run it yourself</p>
      <h2>From source to local gateway.</h2>
      <p class="quickstart-lede">
        PersonalClaw requires Python 3.12. The dashboard opens at
        <code>localhost:10000</code> after the gateway starts.
      </p>
      <CopyCommand command={INSTALL_COMMAND} client:idle />
      <div class="release-note">
        <strong>Package version {releaseFacts.core.versionLabel}.</strong>
        <p>
          {releaseFacts.status.summary}{" "}
          <a href="/release">Inspect the exact sources.</a>
        </p>
      </div>
      <a
        class="button button-primary final-cta"
        href={GITHUB_URL}
        target="_blank"
        rel="noreferrer"
      >
        Read the repository
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .home-hero {
    position: relative;
    height: min(780px, calc(100dvh - 112px));
    min-height: 620px;
    overflow: hidden;
    border-bottom: 1px solid var(--line);
  }

  .home-hero::before {
    position: absolute;
    z-index: 2;
    inset: 0;
    background:
      linear-gradient(90deg, var(--night) 0%, rgba(11, 12, 13, 0.98) 28%, rgba(11, 12, 13, 0.54) 54%, rgba(11, 12, 13, 0.06) 82%),
      linear-gradient(0deg, var(--night) 0%, transparent 30%);
    content: "";
    pointer-events: none;
  }

  .hero-window {
    position: absolute;
    z-index: 1;
    top: 6%;
    right: max(-8rem, calc((100vw - 1700px) / 2));
    width: min(1180px, 76vw);
    animation: window-arrive 700ms 120ms both ease-out;
  }

  .hero-content {
    display: grid;
    position: relative;
    z-index: 3;
    height: 100%;
    align-items: center;
    pointer-events: none;
  }

  .hero-copy {
    width: min(590px, 46vw);
    padding-bottom: 2rem;
    pointer-events: auto;
  }

  .hero-mark {
    width: 62px;
    height: 62px;
    margin-bottom: 1.3rem;
    filter: drop-shadow(0 16px 34px rgba(255, 107, 91, 0.22));
  }

  h1 {
    margin-bottom: 0.45rem;
    font-size: clamp(3.6rem, 8vw, 7rem);
    font-weight: 320;
    line-height: 0.92;
  }

  .hero-line {
    max-width: 11ch;
    margin-bottom: 1.3rem;
    color: var(--coral-bright);
    font-size: clamp(1.45rem, 2.7vw, 2.45rem);
    font-weight: 520;
    line-height: 1.08;
  }

  .hero-support {
    max-width: 38rem;
    margin-bottom: 1.75rem;
    color: var(--ink-soft);
    font-size: 1.08rem;
  }

  .hero-actions {
    display: flex;
    gap: 0.7rem;
    flex-wrap: wrap;
  }

  .hero-facts {
    display: flex;
    margin-top: 1.35rem;
    gap: 1rem;
    flex-wrap: wrap;
    color: var(--ink-muted);
    font-size: 0.82rem;
  }

  .hero-facts span {
    display: inline-flex;
    gap: 0.35rem;
    align-items: center;
  }

  .hero-facts svg {
    color: var(--success);
  }

  .statement {
    display: grid;
    grid-template-columns: 0.5fr 1.5fr;
    gap: 2rem;
    align-items: start;
  }

  .statement .kicker {
    margin-top: 0.75rem;
  }

  .statement h2 {
    max-width: 16ch;
  }

  .ownership-grid {
    display: grid;
    margin-top: clamp(4rem, 9vw, 8rem);
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid var(--line);
  }

  .ownership-grid article {
    position: relative;
    padding: 2.25rem 2.5rem 0 0;
    border-right: 1px solid var(--line);
  }

  .ownership-grid article + article {
    padding-left: 2.5rem;
  }

  .ownership-grid article:last-child {
    border-right: 0;
  }

  .ownership-grid .index {
    position: absolute;
    top: 1rem;
    right: 1rem;
    color: var(--ink-muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }

  .ownership-grid svg {
    margin-bottom: 3.5rem;
    color: var(--coral);
  }

  .ownership-grid h3 {
    margin-bottom: 0.65rem;
    font-size: 1.35rem;
    font-weight: 580;
  }

  .ownership-grid p {
    max-width: 29rem;
    margin: 0;
    color: var(--ink-soft);
  }

  .product-story {
    overflow: hidden;
    background: var(--night-soft);
  }

  .story-layout {
    display: grid;
    grid-template-columns: minmax(280px, 0.7fr) minmax(620px, 1.3fr);
    gap: clamp(3rem, 7vw, 8rem);
    align-items: center;
  }

  .story-copy h2,
  .ecosystem-intro h2,
  .security-copy h2,
  .quickstart h2 {
    margin-bottom: 1.5rem;
    font-size: clamp(2.5rem, 5.5vw, 5rem);
    font-weight: 390;
    line-height: 1;
  }

  .story-copy > p:not(.kicker),
  .security-copy > p:not(.kicker) {
    color: var(--ink-soft);
    font-size: 1.08rem;
  }

  .proof-list {
    display: grid;
    padding: 1.25rem 0;
    gap: 0;
    list-style: none;
  }

  .proof-list li {
    display: flex;
    min-height: 48px;
    gap: 0.75rem;
    align-items: center;
    border-bottom: 1px solid var(--line);
    color: var(--ink-soft);
  }

  .proof-list svg {
    color: var(--coral);
  }

  .text-link {
    display: inline-flex;
    min-height: 44px;
    gap: 0.45rem;
    align-items: center;
    color: var(--coral-bright);
    font-weight: 650;
  }

  .text-link:hover {
    color: var(--ink);
  }

  .story-media {
    margin-right: min(-6vw, -2rem);
  }

  .story-media :global(img),
  .ecosystem-stage :global(img) {
    width: 100%;
    border: 1px solid var(--line-strong);
    border-radius: 8px;
    box-shadow: 0 35px 90px rgba(0, 0, 0, 0.42);
  }

  .system-path {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr auto 1fr auto 1fr;
    align-items: stretch;
    border-block: 1px solid var(--line);
  }

  .system-path article {
    display: flex;
    min-height: 210px;
    padding: 1.4rem;
    flex-direction: column;
  }

  .system-path article > span {
    color: var(--ink-muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
  }

  .system-path svg {
    margin: auto 0 1rem;
    color: var(--coral);
  }

  .system-path h3 {
    margin: 0;
    font-size: 1rem;
    font-weight: 560;
  }

  .path-arrow {
    display: grid;
    min-width: 38px;
    place-items: center;
    color: var(--coral);
  }

  .ecosystem {
    overflow: hidden;
  }

  .ecosystem-intro {
    display: flex;
    gap: 2rem;
    align-items: end;
    justify-content: space-between;
  }

  .ecosystem-intro h2 {
    max-width: 13ch;
    margin-bottom: 0;
  }

  .app-tape {
    display: flex;
    width: max-content;
    margin: 4rem 0;
    gap: 0.55rem;
    transform: translateX(-3rem);
  }

  .app-tape span {
    display: inline-flex;
    min-height: 44px;
    padding: 0.55rem 1rem;
    align-items: center;
    border: 1px solid var(--line-strong);
    border-radius: 999px;
    color: var(--ink-soft);
    white-space: nowrap;
  }

  .ecosystem-stage {
    display: grid;
    grid-template-columns: minmax(260px, 0.5fr) minmax(600px, 1.5fr);
    gap: 3rem;
    align-items: end;
  }

  .ecosystem-note > p {
    color: var(--ink-soft);
    font-size: 1.05rem;
  }

  .ecosystem-note dl {
    display: grid;
    margin: 3rem 0 0;
    gap: 0;
  }

  .ecosystem-note dl div {
    display: grid;
    padding-block: 1rem;
    grid-template-columns: 70px 1fr;
    align-items: baseline;
    border-top: 1px solid var(--line);
  }

  .ecosystem-note dt {
    color: var(--coral);
    font-size: 1.6rem;
    font-weight: 650;
  }

  .ecosystem-note dd {
    margin: 0;
    color: var(--ink-muted);
    font-size: 0.85rem;
  }

  .security-band {
    border-block: 1px solid rgba(255, 107, 91, 0.22);
    background:
      linear-gradient(120deg, rgba(255, 107, 91, 0.1), transparent 38%),
      #0d0e0f;
  }

  .security-layout {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: clamp(3rem, 10vw, 10rem);
    align-items: center;
  }

  .security-copy h2 {
    max-width: 9ch;
  }

  .security-controls {
    border-top: 1px solid var(--line-strong);
  }

  .security-controls article {
    display: grid;
    min-height: 124px;
    padding: 1.5rem 0;
    grid-template-columns: 48px 1fr;
    gap: 1rem;
    align-items: start;
    border-bottom: 1px solid var(--line-strong);
  }

  .security-controls > article > svg {
    color: var(--coral);
  }

  .security-controls h3 {
    margin-bottom: 0.25rem;
    font-size: 1.1rem;
  }

  .security-controls p {
    margin: 0;
    color: var(--ink-muted);
  }

  .quickstart {
    text-align: center;
  }

  .quickstart .kicker {
    justify-content: center;
  }

  .quickstart h2 {
    margin-inline: auto;
  }

  .quickstart-lede {
    max-width: 38rem;
    margin: 0 auto 2.5rem;
    color: var(--ink-soft);
  }

  .quickstart-lede code {
    color: var(--coral-bright);
    font-family: var(--font-mono);
    font-size: 0.85em;
  }

  .quickstart :global(.command-block) {
    text-align: left;
  }

  .release-note {
    display: grid;
    margin-top: 1.25rem;
    padding: 1.25rem 0;
    grid-template-columns: 180px 1fr;
    gap: 1.5rem;
    text-align: left;
    border-block: 1px solid var(--line);
  }

  .release-note strong {
    color: var(--amber);
  }

  .release-note p {
    margin: 0;
    color: var(--ink-muted);
  }

  .release-note a {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    color: var(--coral-bright);
    text-decoration: underline;
    text-decoration-color: rgba(255, 147, 125, 0.4);
    text-underline-offset: 0.2em;
    vertical-align: middle;
  }

  .release-note a:hover {
    color: var(--ink);
  }

  .final-cta {
    margin-top: 2.2rem;
  }

  @keyframes window-arrive {
    from {
      opacity: 0;
      transform: translateX(24px) scale(0.99);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  @media (max-width: 1100px) {
    .hero-window {
      right: -20rem;
      width: 1080px;
    }

    .hero-copy {
      width: min(540px, 60vw);
    }

    .story-layout,
    .ecosystem-stage {
      grid-template-columns: 0.68fr 1.32fr;
      gap: 2.5rem;
    }

    .system-path {
      grid-template-columns: 1fr 1fr 1fr;
    }

    .system-path article {
      min-height: 170px;
      border-right: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
    }

    .system-path article:nth-of-type(3) {
      border-right: 0;
    }

    .system-path article:nth-of-type(n + 4) {
      border-bottom: 0;
    }

    .path-arrow {
      display: none;
    }
  }

  @media (max-width: 820px) {
    .home-hero {
      height: calc(100dvh - 112px);
      min-height: 560px;
      max-height: 732px;
      padding: 0;
    }

    .home-hero::before {
      background: linear-gradient(
        180deg,
        rgba(11, 12, 13, 0.02) 0%,
        rgba(11, 12, 13, 0.28) 36%,
        var(--night) 57%,
        var(--night) 100%
      );
    }

    .hero-content {
      display: grid;
      height: 100%;
      align-items: end;
    }

    .hero-copy {
      width: min(100%, 600px);
      padding-bottom: 1.25rem;
    }

    .hero-window {
      position: absolute;
      z-index: 1;
      top: 0.75rem;
      right: 0;
      left: 0;
      width: calc(100% - 1.25rem);
      margin-inline: auto;
    }

    .hero-mark,
    .hero-support,
    .hero-facts {
      display: none;
    }

    h1 {
      margin-bottom: 0.25rem;
    }

    .hero-line {
      margin-bottom: 1.15rem;
      font-size: 1.3rem;
    }

    .statement,
    .story-layout,
    .ecosystem-stage,
    .security-layout {
      grid-template-columns: 1fr;
    }

    .ownership-grid {
      grid-template-columns: 1fr;
    }

    .ownership-grid article,
    .ownership-grid article + article {
      min-height: 260px;
      padding: 2rem 0;
      border-right: 0;
      border-bottom: 1px solid var(--line);
    }

    .ownership-grid article:last-child {
      border-bottom: 0;
    }

    .ownership-grid svg {
      margin-bottom: 2.5rem;
    }

    .story-media {
      margin: 0;
    }

    .system-path {
      grid-template-columns: 1fr 1fr;
    }

    .system-path article:nth-of-type(3) {
      border-right: 1px solid var(--line);
    }

    .system-path article:nth-of-type(even) {
      border-right: 0;
    }

    .system-path article:nth-of-type(n + 4) {
      border-bottom: 1px solid var(--line);
    }

    .system-path article:last-child {
      border-bottom: 0;
    }

    .ecosystem-intro {
