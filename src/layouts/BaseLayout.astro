---
import "@fontsource-variable/dm-sans";
import "@fontsource-variable/jetbrains-mono";
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "PersonalClaw · Your personal agentic OS",
  description = "A self-hosted agentic operating system for chat, autonomous goals, memory, knowledge, automation, and replaceable apps."
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0b0c0d" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/brand/social-preview.png" />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/brand/personalclaw-mark.svg" />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <Header pathname={pathname} />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
